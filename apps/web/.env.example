# Database Connection (PostgreSQL via Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&connect_timeout=10

# API Base URL (for client-side API calls)
NEXT_PUBLIC_API_URL=https://your-app-domain.com

# AI Generation (Google Gemini API)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# Credits System (Change for production - used for admin grant endpoints)
CREDIT_GRANT_SECRET=change-me-in-production

# Supabase Configuration (Authentication & Storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional: Supabase Storage Bucket (for file uploads)
# SUPABASE_UPLOAD_BUCKET=uploads
